# Client: empty = same-origin /api/v1/* (recommended; avoids CORS). Next rewrites proxy to BACKEND_URL.
# NEXT_PUBLIC_API_BASE_URL=

# Or call the API directly (backend must allow CORS for your frontend origin):
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_BASE_URL=https://backend-53fz.onrender.com

# Server-side rewrite target for /api/v1/* (used when NEXT_PUBLIC_API_BASE_URL is unset).
# Local:
BACKEND_URL=http://127.0.0.1:8000
# Render (mujtabachandio/backend):
# BACKEND_URL=https://backend-53fz.onrender.com
