# Copy to .env.local for local overrides (not committed).

# Server-side rewrites in next.config.mjs — FastAPI base (no trailing slash).
# next.config also sets NEXT_PUBLIC_BACKEND_URL from BACKEND_URL so the browser streams
# SSE directly (same-origin /api rewrites buffer the response until complete).
# BACKEND_URL=http://127.0.0.1:8000

# Production (Vercel / host env): point at your Render API — no trailing slash.
# BACKEND_URL=https://voice-chat-agent-5yf2.onrender.com
# (NEXT_PUBLIC_BACKEND_URL is set from BACKEND_URL in next.config.mjs.)

# WebSockets / SSE use the same base; optional only if the WS host differs:
# NEXT_PUBLIC_WS_URL=wss://voice-chat-agent-5yf2.onrender.com
