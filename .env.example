# Copy to .env.local for local overrides (not committed).

# Server-side rewrites in next.config.mjs — FastAPI base (no trailing slash).
# next.config also sets NEXT_PUBLIC_BACKEND_URL from BACKEND_URL so the browser streams
# SSE directly (same-origin /api rewrites buffer the response until complete).
# BACKEND_URL=http://127.0.0.1:8000

# Production: set BACKEND_URL to your API (https, no trailing slash). Optionally override:
# NEXT_PUBLIC_BACKEND_URL=https://your-api.onrender.com

# WebSockets: NEXT_PUBLIC_BACKEND_URL (http→ws, https→wss).
# Optional override if the WS host differs:
# NEXT_PUBLIC_WS_URL=wss://your-api.onrender.com
